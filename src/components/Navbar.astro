<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-nav">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo + Subtitle -->
      <a href="/" class="flex flex-col items-start group">
        <span class="font-sans text-white tracking-[0.35em] uppercase text-base font-bold group-hover:text-gold transition-colors duration-300">
          THE PALM BEACH BROKER
        </span>
        <span class="font-sans text-gold/80 tracking-widest uppercase text-sm font-light mt-0.5">
                        Danieyis Jimenez Broker Associate | CGI Realty
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/#properties" class="font-sans text-white/80 tracking-widest uppercase text-xs hover:text-gold transition-colors duration-300">Properties</a>
        <a href="/#about" class="font-sans text-white/80 tracking-widest uppercase text-xs hover:text-gold transition-colors duration-300">About</a>
        <a href="/#lifestyle" class="font-sans text-white/80 tracking-widest uppercase text-xs hover:text-gold transition-colors duration-300">Lifestyle</a>
        <a href="/#contact" class="font-sans text-xs tracking-widest uppercase border border-gold text-gold px-6 py-2.5 hover:bg-gold hover:text-white transition-all duration-300">Contact</a>
      </div>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="md:hidden text-white hover:text-gold transition-colors p-2" aria-label="Menu">
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</div>

<!-- Mobile Menu Full Screen Overlay -->
<div id="mobile-menu" class="hidden md:hidden fixed inset-0 top-0 left-0 w-full h-full z-40" style="background: rgba(15,30,20,0.98); backdrop-filter: blur(10px);">
  <div class="flex flex-col h-full">
    <!-- Header of overlay -->
    <div class="flex items-center justify-between px-6 h-20 border-b border-white/10">
      <div class="flex flex-col">
        <span class="font-sans text-white tracking-widest uppercase text-sm font-light">THE PALM BEACH BROKER</span>
        <span class="font-sans text-gold/80 tracking-widest uppercase text-xs font-light mt-0.5">Danieyis Jimenez Broker Associate | CGI Realty</span>
      </div>
      <button id="mobile-close-btn" class="text-white hover:text-gold transition-colors p-2" aria-label="Close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Nav Links -->
    <div class="flex flex-col items-center justify-center flex-1 gap-10">
      <a href="/#properties" class="mobile-link font-sans text-white tracking-[0.4em] uppercase text-lg hover:text-gold transition-colors duration-300">Properties</a>
      <a href="/#about" class="mobile-link font-sans text-white tracking-[0.4em] uppercase text-lg hover:text-gold transition-colors duration-300">About</a>
      <a href="/#lifestyle" class="mobile-link font-sans text-white tracking-[0.4em] uppercase text-lg hover:text-gold transition-colors duration-300">Lifestyle</a>
      <a href="/#contact" class="mobile-link font-sans text-sm tracking-widest uppercase border border-gold text-gold px-10 py-4 hover:bg-gold hover:text-white transition-all duration-300">Contact</a>
    </div>

    <!-- Social icons at bottom -->
