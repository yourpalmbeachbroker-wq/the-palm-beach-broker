---
---

<section id="contact" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Left: Info -->
      <div class="flex flex-col justify-center">
        <p class="font-sans text-gold tracking-widest uppercase text-sm mb-3">Get In Touch</p>
        <h2 class="font-serif text-4xl lg:text-5xl text-forest font-light leading-tight mb-6">
          Let's Find Your<br />
          <span class="text-gold">Perfect Property</span>
        </h2>
        <div class="w-16 h-px bg-gold mb-8"></div>
        <p class="font-sans text-warm-gray-dark leading-relaxed mb-10">
          Whether you're searching for a waterfront estate, a private island retreat, or the perfect investment opportunity in Palm Beach County, I'm here to guide you every step of the way.
        </p>

        <!-- Contact Details -->
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-gold flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-1">Phone</p>
              <a href="tel:+15615550199" class="font-serif text-forest text-lg hover:text-gold transition-colors">(561) 555-0199</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-gold flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-1">Email</p>
              <a href="mailto:hello@thepalmbeachbroker.com" class="font-serif text-forest text-lg hover:text-gold transition-colors">hello@thepalmbeachbroker.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-gold flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-1">Office</p>
              <p class="font-serif text-forest text-lg">Palm Beach, Florida 33480</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form (Netlify Forms) -->
      <div class="bg-warm-gray p-8 lg:p-12">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          action="/success"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="first-name" class="block font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-2">First Name</label>
              <input
                type="text"
                id="first-name"
                name="first-name"
                required
                class="w-full bg-white border border-gray-200 px-4 py-3 font-sans text-forest focus:outline-none focus:border-gold transition-colors"
                placeholder="James"
              />
            </div>
            <div>
              <label for="last-name" class="block font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-2">Last Name</label>
              <input
                type="text"
                id="last-name"
                name="last-name"
                required
                class="w-full bg-white border border-gray-200 px-4 py-3 font-sans text-forest focus:outline-none focus:border-gold transition-colors"
                placeholder="Morrison"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-2">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-white border border-gray-200 px-4 py-3 font-sans text-forest focus:outline-none focus:border-gold transition-colors"
              placeholder="james@example.com"
            />
          </div>

          <div>
            <label for="phone" class="block font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-2">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full bg-white border border-gray-200 px-4 py-3 font-sans text-forest focus:outline-none focus:border-gold transition-colors"
              placeholder="(561) 000-0000"
            />
          </div>

          <div>
            <label for="interest" class="block font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-2">I'm Interested In</label>
            <select
              id="interest"
              name="interest"
              class="w-full bg-white border border-gray-200 px-4 py-3 font-sans text-forest focus:outline-none focus:border-gold transition-colors appearance-none"
            >
              <option value="">Select an option...</option>
              <option value="buying">Buying a Property</option>
              <option value="selling">Selling a Property</option>
              <option value="both">Buying & Selling</option>
              <option value="investment">Investment Properties</option>
              <option value="rental">Luxury Rentals</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-sans text-xs tracking-widest uppercase text-warm-gray-dark mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full bg-white border border-gray-200 px-4 py-3 font-sans text-forest focus:outline-none focus:border-gold transition-colors resize-none"
              placeholder="Tell me about your dream property..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-gold text-white font-sans text-xs tracking-widest uppercase py-4 px-8 hover:bg-gold/90 transition-all duration-300"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
