---
---
<section
  id="contact"
  class="relative py-20 overflow-hidden"
  style="background-image: url('https://images.unsplash.com/photo-1533106497176-45ae19e68ba2?w=1920&q=80'); background-size: cover; background-position: center;"
>
  <!-- Dark overlay for readability -->
  <div class="absolute inset-0 bg-forest/85"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Left: Info -->
      <div class="flex flex-col justify-center">
        <p class="font-sans text-gold tracking-widest uppercase text-sm mb-3">Get In Touch</p>
        <h2 class="font-serif text-4xl lg:text-5xl text-white font-light leading-tight mb-6">
          Let's Find Your<br />
          <span class="text-gold">Perfect Property</span>
        </h2>
        <div class="w-16 h-px bg-gold mb-8"></div>
        <p class="font-sans text-white/80 leading-relaxed mb-10">
          Whether you're searching for a waterfront estate, a private island retreat, or the perfect investment opportunity in Palm Beach County, I'm here to guide you every step of the way.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-gold flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <div>
              <p class="font-sans text-xs tracking-widest uppercase text-white/60 mb-1">Phone / WhatsApp</p>
              <a href="tel:+17869758002" class="font-serif text-white text-lg hover:text-gold transition-colors">+1 (786) 975-8002</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-gold flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <p class="font-sans text-xs tracking-widest uppercase text-white/60 mb-1">Email</p>
              <a href="mailto:yourpalmbeachbroker@gmail.com" class="font-serif text-white text-lg hover:text-gold transition-colors">yourpalmbeachbroker@gmail.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-gold flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <p class="font-sans text-xs tracking-widest uppercase text-white/60 mb-1">Office</p>
              <p class="font-serif text-white text-lg">Palm Beach, Florida 33480</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-white/10 backdrop-blur-md border border-white/20 p-8">
        <h3 class="font-serif text-2xl text-white font-light mb-6">Send a Message</h3>
        <form action="https://formspree.io/f/mzzzqgpq" method="POST" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block font-sans text-xs tracking-widest uppercase text-white/70 mb-2">First Name</label>
              <input type="text" name="first_name" required placeholder="John" class="w-full bg-white/10 border border-white/30 text-white placeholder-white/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-gold transition-colors" />
            </div>
            <div>
              <label class="block font-sans text-xs tracking-widest uppercase text-white/70 mb-2">Last Name</label>
              <input type="text" name="last_name" required placeholder="Smith" class="w-full bg-white/10 border border-white/30 text-white placeholder-white/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-gold transition-colors" />
            </div>
          </div>
          <div>
            <label class="block font-sans text-xs tracking-widest uppercase text-white/70 mb-2">Email Address</label>
            <input type="email" name="email" required placeholder="john@example.com" class="w-full bg-white/10 border border-white/30 text-white placeholder-white/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-gold transition-colors" />
          </div>
          <div>
            <label class="block font-sans text-xs tracking-widest uppercase text-white/70 mb-2">Phone Number</label>
            <input type="tel" name="phone" placeholder="+1 (___) ___-____" class="w-full bg-white/10 border border-white/30 text-white placeholder-white/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-gold transition-colors" />
          </div>
          <div>
            <label class="block font-sans text-xs tracking-widest uppercase text-white/70 mb-2">I'm Interested In</label>
            <select name="interest" class="w-full bg-white/10 border border-white/30 text-white px-4 py-3 font-sans text-sm focus:outline-none focus:border-gold transition-colors">
              <option value="buying" class="text-gray-900">Buying a Property</option>
              <option value="selling" class="text-gray-900">Selling a Property</option>
              <option value="investment" class="text-gray-900">Investment Opportunities</option>
              <option value="rental" class="text-gray-900">Luxury Rentals</option>
              <option value="other" class="text-gray-900">Other</option>
            </select>
          </div>
          <div>
            <label class="block font-sans text-xs tracking-widest uppercase text-white/70 mb-2">Message</label>
            <textarea name="message" rows="4" placeholder="Tell me about your dream property..." class="w-full bg-white/10 border border-white/30 text-white placeholder-white/40 px-4 py-3 font-sans text-sm focus:outline-none focus:border-gold transition-colors resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-gold text-white font-sans text-xs tracking-widest uppercase py-4 hover:bg-gold/90 transition-all duration-300">
            Send Message
          </button>
            <p class='text-xs text-white/60 leading-relaxed mt-3'>I agree to be contacted by <strong class='text-white/80'>The Palm Beach Broker</strong> via call, email, and text for real estate services. To opt out, you can reply STOP at any time or reply HELP for assistance. You can also click the unsubscribe link in the emails. Message and data rates may apply. Message frequency may vary. <a href='/privacy-policy' class='text-gold underline hover:text-white transition-colors'>Privacy Policy</a></p>
        </form>
      </div>
    </div>
  </div>
</section>
