---
const testimonials = [
  {
    quote: "She found us our dream home in Palm Beach Island within weeks. Her market knowledge and dedication are truly unmatched.",
    author: "James & Sarah M.",
    location: "Palm Beach Island",
    stars: 5
  },
  {
    quote: "The most professional and attentive broker I have ever worked with. She negotiated an exceptional deal on our oceanfront estate.",
    author: "Robert K.",
    location: "Manalapan, FL",
    stars: 5
  },
  {
    quote: "Sold our property above asking price in just 10 days. Her network and marketing strategy are second to none.",
    author: "Patricia L.",
    location: "Gulf Stream, FL",
    stars: 5
  }
];
---

<section class="py-20 bg-forest">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="font-sans text-gold tracking-widest uppercase text-sm mb-3">Client Stories</p>
      <h2 class="font-serif text-4xl lg:text-5xl text-white font-light">
        What Our Clients Say
      </h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white/5 border border-gold/20 p-8 hover:border-gold/60 transition-all duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-6">
            {Array(t.stars).fill(0).map(() => (
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <!-- Quote -->
          <blockquote class="font-serif text-white/90 text-lg leading-relaxed mb-8 italic">
            &ldquo;{t.quote}&rdquo;
          </blockquote>
          <!-- Author -->
          <div class="border-t border-gold/20 pt-6">
            <p class="font-sans text-white font-medium">{t.author}</p>
            <p class="font-sans text-gold text-sm tracking-wide mt-1">{t.location}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-14">
      <a
        href="https://www.zillow.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block border border-gold text-gold text-xs tracking-widest uppercase py-4 px-10 font-sans hover:bg-gold hover:text-forest transition-all duration-300"
      >
        Read More Reviews
      </a>
    </div>
  </div>
</section>
