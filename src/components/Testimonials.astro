---
const reviews = [
  {
    name: "LAURA GARCIA",
    role: "Home Buyer",
    content: "Dani is truly exceptional. She is honest, sincere, and genuinely cares about her clients. From the very beginning, she was always attentive and supportive during our home search. She was incredibly patient with us and consistently protected our interests.",
    rating: 5
  },
  {
    name: "Cartier Thomas",
    role: "Tenant",
    content: "I can’t say enough good things about Danieyis Jiminez! Even though she was the landlord’s agent, she made our rental process feel like we were her top priority from day one. She was incredibly kind, patient, professional, and genuinely caring.",
    rating: 5
  },
  {
    name: "Luna Feliciano",
    role: "Home Buyer",
    content: "Dani was absolutely incredible. She fought to get us all the best accommodations, she took her time to answer all our questions and concerns. She searched exactly for our needs and wants in every single home until we found the one.",
    rating: 5
  },
  {
    name: "Maria Rodriguez",
    role: "Seller",
    content: "Excellent service! Dani made the process of selling our home so easy. Her knowledge of the Palm Beach market is unmatched. Highly recommend her for anyone looking for a professional and dedicated agent.",
    rating: 5
  },
  {
    name: "John Smith",
    role: "Investor",
    content: "Danieyis is the best broker I've worked with in Florida. She understands the numbers and the market. Very responsive and always professional. A true partner for any real estate investor.",
    rating: 5
  }
];

// Duplicate reviews for infinite scroll effect
const allReviews = [...reviews, ...reviews];
---

<section id="testimonials" class="py-24 bg-forest overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16 text-center">
    <p class="text-gold tracking-[0.3em] uppercase text-xs font-sans font-light mb-4">Testimonials</p>
    <h2 class="font-serif text-3xl sm:text-4xl text-white font-light">Client Experiences</h2>
    <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
  </div>

  <div class="relative w-full overflow-hidden">
    <!-- Moving Track -->
    <div class="flex animate-scroll whitespace-nowrap">
      {allReviews.map((review) => (
        <div class="inline-block w-[350px] sm:w-[450px] px-4 whitespace-normal">
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 h-full flex flex-col justify-between hover:border-gold/50 transition-colors duration-500">
            <div>
              <div class="flex gap-1 mb-6">
                {[...Array(review.rating)].map(() => (
                  <svg class="w-4 h-4 text-gold fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="font-sans text-white/80 text-lg leading-relaxed italic mb-8">
                "{review.content}"
              </p>
            </div>
            <div class="flex items-center gap-4 border-t border-white/10 pt-6 mt-auto">
              <div class="w-10 h-10 bg-gold/20 flex items-center justify-center text-gold font-serif text-xl">
                {review.name[0]}
              </div>
              <div>
                <p class="font-serif text-white text-base tracking-wide uppercase">{review.name}</p>
                <p class="font-sans text-gold/60 text-xs tracking-widest uppercase mt-1">{review.role}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  
  <div class="text-center mt-16">
    <a 
      href="https://www.google.com/search?q=Danieyis+Jimenez+The+Palm+Beach+Broker+Reviews" 
      target="_blank" 
      class="inline-block border border-gold text-gold px-8 py-3 uppercase tracking-widest text-xs hover:bg-gold hover:text-forest transition-all duration-300"
    >
      View All Google Reviews
    </a>
  </div>
</section>

<style>
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-scroll {
    display: flex;
    width: max-content;
    animation: scroll 40s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }
</style>
