---
const partners = [
  { name: 'Zillow', url: 'https://www.zillow.com/', logo: '/logos/zillow.png' },
  { name: 'InvestorLift', url: 'https://investorlift.com/marketplace/', logo: '/logos/investorlift.png' },
  { name: 'Realtor.com', url: 'https://www.realtor.com/', logo: '/logos/realtor.png' },
  { name: 'Redfin', url: 'https://www.redfin.com/', logo: '/logos/redfin.png' }
];
---
<section id="partners" class="py-20 bg-white border-y border-forest/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-serif text-3xl sm:text-4xl text-forest font-light">Find more properties here</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 items-center justify-items-center">
      {partners.map(partner => (
        <a 
          href={partner.url} 
          target="_blank" 
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-6 transition-all duration-500 w-full max-w-[200px]"
        >
          <div class="w-full h-20 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all duration-500 opacity-70 group-hover:opacity-100">
            <img 
              src={partner.logo} 
              alt={partner.name} 
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <div class="flex flex-col items-center">
            <span class="font-serif text-lg text-forest/60 group-hover:text-gold transition-colors">{partner.name}</span>
            <span class="font-sans text-[10px] tracking-[0.2em] uppercase text-forest/40 group-hover:text-gold transition-colors mt-1">Visit Website</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
