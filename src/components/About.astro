---
---

<section id="about" class="py-20 bg-warm-gray">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Image -->
      <div class="relative">
        <div class="aspect-[4/5] bg-forest rounded-sm overflow-hidden shadow-2xl">
          <img
            src="/broker-photo.jpg"
            alt="The Palm Beach Broker"
            class="w-full h-full object-cover"
            onerror="this.style.background='#2D5016'; this.style.display='flex';"
          />
          <!-- Fallback overlay if no image -->
          <div class="absolute inset-0 flex items-center justify-center bg-forest">
            <div class="text-center text-white p-8">
              <div class="w-32 h-32 rounded-full bg-gold/20 border-2 border-gold mx-auto mb-4 flex items-center justify-center">
                <svg class="w-16 h-16 text-gold" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                </svg>
              </div>
              <p class="font-sans text-gold tracking-widest text-sm uppercase">Your Palm Beach Broker</p>
            </div>
          </div>
        </div>
        <!-- Gold accent border -->
        <div class="absolute -bottom-4 -right-4 w-full h-full border-2 border-gold rounded-sm -z-10"></div>
      </div>

      <!-- Content -->
      <div>
        <p class="font-sans text-gold tracking-widest uppercase text-sm mb-3">Meet Your Broker</p>
        <h2 class="font-serif text-4xl lg:text-5xl text-forest font-light leading-tight mb-6">
          Luxury Real Estate<br />
          <span class="text-gold">Expertise & Passion</span>
        </h2>
        <div class="w-16 h-px bg-gold mb-8"></div>
        <p class="font-sans text-warm-gray-dark text-lg leading-relaxed mb-6">
          With years of experience in Palm Beach's most exclusive neighborhoods, I bring unparalleled market knowledge and a deeply personal approach to every transaction.
        </p>
        <p class="font-sans text-warm-gray-dark leading-relaxed mb-8">
          From waterfront estates to hidden gems in Palm Beach Island, Manalapan, and Gulf Stream, I specialize in matching discerning buyers with extraordinary properties that reflect their lifestyle and aspirations.
        </p>

        <!-- Highlights -->
        <div class="grid grid-cols-2 gap-6 mb-10">
          <div class="border-l-2 border-gold pl-4">
            <p class="font-serif text-3xl text-forest">$500M+</p>
            <p class="font-sans text-sm text-warm-gray-dark tracking-wide uppercase mt-1">In Sales Volume</p>
          </div>
          <div class="border-l-2 border-gold pl-4">
            <p class="font-serif text-3xl text-forest">15+</p>
            <p class="font-sans text-sm text-warm-gray-dark tracking-wide uppercase mt-1">Years Experience</p>
          </div>
          <div class="border-l-2 border-gold pl-4">
            <p class="font-serif text-3xl text-forest">200+</p>
            <p class="font-sans text-sm text-warm-gray-dark tracking-wide uppercase mt-1">Families Served</p>
          </div>
          <div class="border-l-2 border-gold pl-4">
            <p class="font-serif text-3xl text-forest">#1</p>
            <p class="font-sans text-sm text-warm-gray-dark tracking-wide uppercase mt-1">Palm Beach Specialist</p>
          </div>
        </div>

        <a
          href="#contact"
          class="inline-block border border-forest text-forest text-xs tracking-widest uppercase py-4 px-10 font-sans hover:bg-forest hover:text-white transition-all duration-300"
        >
          Work With Me
        </a>
      </div>
    </div>
  </div>
</section>
