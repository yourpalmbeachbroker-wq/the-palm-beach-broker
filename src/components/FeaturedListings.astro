---

<section id="properties" class="relative py-24 overflow-hidden">
  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 w-full h-full object-cover opacity-25"
  >
    <source src="/2231485-uhd_3840_2160_24fps.mp4" type="video/mp4" />
  </video>

  <!-- Overlay oscuro para contraste -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/85 via-black/85 to-black/95"></div>

  <!-- Contenido -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
      <div>
        <p class="font-sans text-xs tracking-[0.3em] uppercase text-gold mb-4">
          Curated Selection
        </p>
        <h2 class="font-serif text-3xl md:text-4xl text-white mb-3">
          Featured Properties
        </h2>
        <p class="font-sans text-sm text-white/70 max-w-xl">
          A selection of homes successfully represented by Danieyis across Palm Beach, Miami and South Florida, highlighting a proven track record of closed transactions.
        </p>
      </div>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {sales.map((sale) => (
        <article class="group bg-black/75 border border-white/10 flex flex-col backdrop-blur-sm">
          <div class="relative overflow-hidden">
            <img
              src={sale.image}
              alt={sale.address + ", " + sale.city}
              class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <span class="absolute top-4 left-4 bg-emerald-500 text-[10px] tracking-[0.25em] uppercase px-3 py-1">
              Sold
            </span>
            <span class="absolute top-4 right-4 bg-white/90 text-[10px] tracking-[0.25em] uppercase px-3 py-1 text-black">
              {sale.role}
            </span>
          </div>

          <div class="flex-1 p-6 space-y-3">
            <p class="font-sans text-[11px] tracking-[0.25em] uppercase text-white/60">
              {sale.city}
            </p>
            <h3 class="font-serif text-lg text-white">
              {sale.address}
            </h3>
            <p class="font-sans text-sm text-white/60">
              {sale.details}
            </p>
            <p class="font-sans text-sm text-gold">
              Sold for {sale.soldPrice}
            </p>
          </div>

          <div class="px-6 pb-6 mt-auto">
            <a
              href={sale.zillowUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-[11px] tracking-[0.3em] uppercase text-white hover:text-gold"
            >
              View details
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>


