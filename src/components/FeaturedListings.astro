---

<section id="properties" class="relative py-24 overflow-hidden">
  <!-- YouTube Video Background -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <iframe
      src="https://www.youtube.com/embed/SL_-o0JBWWM?autoplay=1&mute=1&loop=1&playlist=SL_-o0JBWWM&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1"
      class="absolute w-[300%] h-[300%] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
      style="border:0;"
      allow="autoplay; encrypted-media"
      allowfullscreen
      title="Ocean background"
    ></iframe>
    <div class="absolute inset-0 bg-forest/80"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="font-sans text-gold tracking-widest uppercase text-sm mb-2">Curated Selection</p>
      <h2 class="font-serif text-4xl sm:text-5xl text-white font-light">Featured Properties</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>

    <!-- Listings Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {listings.map((listing) => (
        <div class="group bg-white/5 backdrop-blur-sm border border-white/10 hover:border-gold/40 transition-all duration-500 overflow-hidden">
          <div class="relative overflow-hidden">
            <img
              src={listing.image}
              alt={listing.name}
              class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute top-4 left-4">
              <span class={`font-sans text-xs tracking-widest uppercase px-3 py-1 ${
                listing.status === 'Sold'
                  ? 'bg-gold text-forest'
                  : 'bg-white/20 text-white border border-white/30'
              }`}>{listing.tag}</span>
            </div>
            <div class="absolute bottom-4 right-4">
              <span class="font-serif text-xl text-white font-light">{listing.soldPrice}</span>
            </div>
            {listing.status === 'Sold' &&
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            }
          </div>

          <div class="p-6">
            <h3 class="font-serif text-lg text-white mb-1">{listing.name}</h3>
            <p class="font-sans text-gold/70 text-xs tracking-widest uppercase mb-3">&#9679; {listing.location}</p>
            <p class="font-sans text-white/50 text-xs mb-4">{listing.address}</p>
            <p class="font-sans text-white/60 text-sm mb-4 leading-relaxed">{listing.description}</p>

            <div class="flex gap-4 text-white/50 text-xs font-sans tracking-wide mb-5">
              <span>{listing.beds} Beds</span>
              <span>&bull;</span>
              <span>{listing.baths} Baths</span>
              <span>&bull;</span>
              <span>{listing.sqft} sqft</span>
            </div>

            {listing.status === 'Sold' && (
              <p class="font-sans text-xs text-gold/70 mb-4">
                <span class="text-white/40">Buyer: </span>{listing.buyer}
              </p>
            )}

            <a
              href="/#contact"
              class="inline-block font-sans text-xs tracking-widest uppercase border border-gold text-gold px-6 py-2.5 hover:bg-gold hover:text-forest transition-all duration-300"
            >
              {listing.status === 'Sold' ? 'View Details' : 'Inquire Now'}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a
        href="/#contact"
        class="inline-block font-sans text-xs tracking-widest uppercase border border-gold/50 text-gold/80 px-10 py-4 hover:border-gold hover:text-gold transition-all duration-300"
      >
        View All Properties
      </a>
    </div>

    <!-- Tagline -->
    <div class="text-center mt-12 border-t border-white/10 pt-10">
      <p class="font-serif text-white/40 text-sm tracking-wide">THE PALM BEACH BROKER &mdash; Your Trusted Real Estate Partner</p>
      <blockquote class="font-serif text-white/25 text-sm italic mt-2">&ldquo;Your needs, always my priority.&rdquo;</blockquote>
    </div>
  </div>
</section>
