    address: '10273 Showboat Lane, Royal Palm Beach, FL 33411',
    description: 'Single Family Residence built in 1978. Heated pool, water view.'
  },
  {
    image: 'https://photos.zillowstatic.com/p_e/ISv5is7xof0pzd0000000000.jpg',
    name: 'Huntington Lane Condo',
    location: 'Delray Beach',
    beds: 2,
    baths: 2,
    sqft: '1,230',
    price: '$305,000',
    tag: 'Sold',
    status: 'Sold',
    address: '7076 Huntington Lane #707, Delray Beach, FL 33446',
    description: 'Condominium built in 1985. Lake view, gated community.'
  },
  {
    image: 'https://photos.zillowstatic.com/p_e/IS7q68u5f90pzd0000000000.jpg',
    name: 'N Haverhill Road Unit',
    location: 'West Palm Beach',
    beds: 3,
    baths: 2,
    sqft: '1,191',
    price: '$265,000',
    tag: 'Sold',
    status: 'Sold',
    address: '4197 N Haverhill Road #216, West Palm Beach, FL 33417',
    description: 'Condominium built in 2000. Gated community, garden view.'
  },
  {
    image: 'https://photos.zillowstatic.com/p_e/ISr98v1xof0pzd0000000000.jpg',
    name: 'Northampton St Condo',
    location: 'West Palm Beach',
    beds: 1,
    baths: 2,
    sqft: '684',
    price: '$94,000',
    tag: 'Sold',
    status: 'Sold',
    address: '5 Northampton St #5-A, West Palm Beach, FL 33417',
    description: 'Condominium built in 1972. Corner unit, garden view.'
  },
  {
    image: 'https://photos.zillowstatic.com/p_e/ISv5q3r1o8yzd0000000000.jpg',
    name: 'W Lake Drive Ranch',
    location: 'Lake Clarke Shores',
    beds: 3,
    baths: 3,
    sqft: '1,670',
    price: '$725,000',
