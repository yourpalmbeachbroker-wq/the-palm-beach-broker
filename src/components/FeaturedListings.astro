---

<section id="properties" class="relative pt-20 pb-20 overflow-hidden">
  <!-- Ocean/beach background image -->
  <div class="absolute inset-0 z-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=80');"></div>
  <div class="absolute inset-0 z-0 bg-gradient-to-b from-black/70 via-black/55 to-black/75"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="font-sans text-gold tracking-widest uppercase text-sm mb-3">Curated Selection</p>
      <h2 class="font-serif text-4xl lg:text-5xl text-white font-light">Featured Properties</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {listings.map((listing) => (
        <div class="group bg-white/10 backdrop-blur-sm border border-white/15 hover:border-gold/50 transition-all duration-500 overflow-hidden">
          <div class="relative overflow-hidden h-56">
            <img src={listing.image} alt={listing.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <span class="absolute top-4 left-4 bg-red-600 text-white font-sans text-xs tracking-widest uppercase px-3 py-1">{listing.tag}</span>
            <div class="absolute bottom-4 left-4">
              <p class="font-serif text-white text-xl font-light">{listing.price}</p>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-serif text-white text-xl font-light mb-1">{listing.name}</h3>
            <p class="font-sans text-gold text-xs tracking-widest uppercase mb-2">&#9679; {listing.location}</p>
            <p class="font-sans text-white/60 text-xs mb-4">{listing.address}</p>
            <p class="font-sans text-white/70 text-sm mb-4">{listing.description}</p>
            <div class="flex items-center gap-5 font-sans text-white/70 text-xs mb-6">
              <span>{listing.beds} Beds</span>
              <span>{listing.baths} Baths</span>
              <span>{listing.sqft} sqft</span>
            </div>
            <a href="/#contact" class="block text-center border border-gold text-gold font-sans text-xs tracking-widest uppercase py-3 hover:bg-gold hover:text-white transition-all duration-300">View Details</a>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/#contact" class="inline-block border border-white text-white font-sans text-xs tracking-widest uppercase py-4 px-10 hover:bg-white hover:text-forest transition-all duration-300">View All Properties</a>
    </div>
  </div>
</section>

<!-- Quote Bar - Elegant & Sophisticated -->
<div class="relative bg-gradient-to-r from-gold via-gold to-gold py-28 px-4 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 left-10 w-64 h-64 bg-white rounded-full mix-blend-multiply filter blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-64 h-64 bg-white rounded-full mix-blend-multiply filter blur-3xl"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto text-center">
    <!-- Decorative top ornament -->
    <div class="flex items-center justify-center gap-6 mb-12">
      <div class="h-px w-16 bg-white/40"></div>
      <div class="flex gap-2">
        <span class="inline-block w-2 h-2 bg-white/60 rounded-full"></span>
        <span class="inline-block w-2 h-2 bg-white/60 rounded-full"></span>
        <span class="inline-block w-2 h-2 bg-white/60 rounded-full"></span>
      </div>
      <div class="h-px w-16 bg-white/40"></div>
    </div>

    <!-- Main quote with sophisticated styling -->
    <blockquote class="mb-12">
      <p class="font-serif text-white text-5xl sm:text-6xl lg:text-8xl font-light leading-tight tracking-tight mb-4">
        Your needs,
      </p>
      <p class="font-serif text-white text-5xl sm:text-6xl lg:text-8xl font-light leading-tight tracking-tight italic">
        always my priority.
      </p>
    </blockquote>

    <!-- Decorative bottom ornament -->
    <div class="flex items-center justify-center gap-6 mt-12">
      <div class="h-px w-16 bg-white/40"></div>
      <div class="flex gap-3">
        <span class="inline-block w-1.5 h-1.5 bg-white/50 rounded-full"></span>
        <span class="inline-block w-1.5 h-1.5 bg-white/50 rounded-full"></span>
        <span class="inline-block w-1.5 h-1.5 bg-white/50 rounded-full"></span>
      </div>
      <div class="h-px w-16 bg-white/40"></div>
    </div>
  </div>
</div>
