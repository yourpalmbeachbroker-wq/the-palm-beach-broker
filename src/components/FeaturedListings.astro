---
const listings = [
  {
    image: 'https://photos.zillowstatic.com/p_e/ISvx5lfzfxqvzd0000000000.jpg',
    name: 'Dartford Trail Condo',
    location: 'Wellington',
    beds: 3,
    baths: 2,
    sqft: '1,300',
    price: '$300,000',
    soldPrice: '$300,000',
    tag: 'Sold',
    status: 'Sold',
    description: 'Beautiful condo in Wellington with modern amenities and spacious living areas.',
    address: '12970 Dartford Trail #4, Wellington, FL 33414',
    buyer: 'Represented Buyer'
  },
  {
    image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&q=80',
    name: 'Port Saint Lucie Property',
    location: 'Port Saint Lucie',
    beds: 3,
    baths: 2,
    sqft: '1,200',
    price: '$374,000',
    soldPrice: '$374,000',
    tag: 'Sold',
    status: 'Sold',
    description: 'Excellent property in Port Saint Lucie with great investment potential.',
    address: '834 SE Walters Ter, Port Saint Lucie, FL 34983',
    buyer: 'Represented Buyer'
  },
  {
    image: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=600&q=80',
    name: 'Miami Investment Property',
    location: 'Miami',
    beds: 2,
    baths: 2,
    sqft: '900',
    price: '$285,000',
    soldPrice: '$285,000',
    tag: 'Sold',
    status: 'Sold',
    description: 'Strategic investment property in Miami with strong appreciation potential.',
    address: '1300 NE 109th Street #207, Miami, FL 33161',
    buyer: 'Represented Seller'
  },
  {
    image: 'https://images.unsplash.com/photo-1567496898669-ee935f5f647a?w=600&q=80',
    name: 'Miami Estate',
    location: 'Miami',
    beds: 4,
    baths: 3,
    sqft: '2,500',
    price: '$780,000',
    soldPrice: '$780,000',
    tag: 'Sold',
    status: 'Sold',
    description: 'Premium estate property in Miami with excellent location and features.',
    address: '11290 SW 48 Street, Miami, FL 33165',
    buyer: 'Represented Seller'
  },
  {
    image: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=600&q=80',
    name: 'Royal Palm Beach Luxury Home',
    location: 'Royal Palm Beach',
    beds: 4,
    baths: 3,
    sqft: '2,200',
    price: '$580,000',
    soldPrice: '$580,000',
    tag: 'Sold',
    status: 'Sold',
    description: 'Stunning luxury home in Royal Palm Beach with premium finishes.',
    address: '10273 Showboat Ln, Royal Palm Beach, FL 33411',
    buyer: 'Represented Buyer'
  },
  {
    image: 'https://images.unsplash.com/photo-1416331108676-a22ccb276e35?w=600&q=80',
    name: 'Fort Lauderdale Property',
    location: 'Fort Lauderdale',
    beds: 2,
    baths: 2,
    sqft: '1,100',
    price: '$520,000',
    soldPrice: '$520,000',
    tag: 'For Sale',
    status: 'Coming Soon',
    description: 'Exceptional property in the heart of Fort Lauderdale, close to the beach.',
    address: 'Fort Lauderdale, FL',
    buyer: ''
  },
];
---

<section id="properties" class="py-20 bg-forest">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="font-sans text-gold tracking-widest uppercase text-sm mb-2">Curated Selection</p>
      <h2 class="font-serif text-4xl sm:text-5xl text-white font-light">Featured Properties</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>

    <!-- Listings Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {listings.map((listing) => (
        <div class="group bg-white/5 backdrop-blur-sm border border-white/10 hover:border-gold/40 transition-all duration-500 overflow-hidden">
          <div class="relative overflow-hidden">
            <img
              src={listing.image}
              alt={listing.name}
              class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute top-4 left-4">
              <span class={`font-sans text-xs tracking-widest uppercase px-3 py-1 ${
                listing.status === 'Sold'
                  ? 'bg-gold text-black'
                  : 'bg-white/20 text-white border border-white/30'
              }`}>{listing.tag}</span>
            </div>
            <div class="absolute bottom-4 right-4">
              <span class="font-serif text-xl text-white font-light">{listing.soldPrice}</span>
            </div>
            {listing.status === 'Sold' && (
              <div class="absolute inset-0 bg-black/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="w-24 h-24 border-2 border-gold rounded-full flex items-center justify-center transform -rotate-12">
                  <span class="text-gold font-serif text-xl">SOLD</span>
                </div>
              </div>
            )}
          </div>
          <div class="p-8">
            <div class="flex items-center text-gold/70 text-xs font-sans tracking-widest uppercase mb-3">
              <span class="w-8 h-px bg-gold/30 mr-3"></span>
              {listing.location}
            </div>
            <h3 class="font-serif text-white text-2xl mb-1">{listing.name}</h3>
            <p class="text-white/60 text-sm font-sans mb-4">{listing.address}</p>
            <p class="text-white/40 text-sm font-sans leading-relaxed mb-4 line-clamp-2">{listing.description}</p>
            <div class="flex justify-between items-center py-6 border-y border-white/10 mb-6">
              <div class="text-center">
                <p class="text-white font-serif text-lg">{listing.beds}</p>
                <p class="text-white/40 text-[10px] uppercase tracking-widest">Beds</p>
              </div>
              <div class="w-px h-8 bg-white/10"></div>
              <div class="text-center">
                <p class="text-white font-serif text-lg">{listing.baths}</p>
                <p class="text-white/40 text-[10px] uppercase tracking-widest">Baths</p>
              </div>
              <div class="w-px h-8 bg-white/10"></div>
              <div class="text-center">
                <p class="text-white font-serif text-lg">{listing.sqft}</p>
                <p class="text-white/40 text-[10px] uppercase tracking-widest">Sq Ft</p>
              </div>
            </div>
            {listing.status === 'Sold' && (
              <div class="mb-6 flex items-center text-gold/60 text-xs font-sans italic">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-gold/60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {listing.buyer}
              </div>
            )}
            <a
              href={listing.status === 'Sold' ? 'https://www.zillow.com/profile/danirealtor0#listings-and-sales' : '#contact'}
              target={listing.status === 'Sold' ? '_blank' : '_self'}
              class="block w-full text-center py-4 border border-gold/30 text-gold text-xs font-sans tracking-widest uppercase hover:bg-gold hover:text-black transition-all duration-300"
            >
              {listing.status === 'Sold' ? 'View Details' : 'Inquire Now'}
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-20 text-center">
      <a
        href="https://www.zillow.com/profile/danirealtor0#listings-and-sales"
        target="_blank"
        class="inline-block px-12 py-5 bg-gold text-black text-xs font-sans tracking-widest uppercase hover:bg-white transition-all duration-300"
      >
        View All Properties
      </a>
    </div>
  </div>
</section>

<!-- Tagline Section - Creative & Dynamic -->
<section class="relative py-20 overflow-hidden bg-forest">
  <!-- Beach image background -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=80"
      alt="Palm Beach"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(26,54,42,0.85) 0%, rgba(26,54,42,0.6) 50%, rgba(26,54,42,0.85) 100%);"></div>
  </div>

  <!-- Decorative gold lines -->
  <div class="absolute top-0 left-0 w-full h-px bg-gold/30"></div>
  <div class="absolute bottom-0 left-0 w-full h-px bg-gold/30"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <!-- Small label -->
    <p class="font-sans text-gold/80 tracking-widest uppercase text-xs mb-8 flex items-center justify-center gap-4">
      <span class="w-12 h-px bg-gold/40"></span>
      My Commitment
      <span class="w-12 h-px bg-gold/40"></span>
    </p>

    <!-- Large quote mark -->
    <div class="font-serif text-gold/20 text-9xl leading-none mb-2 select-none">&ldquo;</div>

    <!-- Main quote -->
    <blockquote class="font-serif text-white text-4xl md:text-5xl lg:text-6xl font-light leading-tight -mt-12">
      Your needs,
      <span class="block text-gold italic">always my priority.</span>
    </blockquote>

    <!-- Signature line -->
    <div class="mt-10 flex items-center justify-center gap-6">
      <div class="h-px w-16 bg-gold/50"></div>
      <span class="font-sans text-white/70 text-sm tracking-widest uppercase">Danieyis Jimenez</span>
      <div class="h-px w-16 bg-gold/50"></div>
    </div>
  </div>
</section>
