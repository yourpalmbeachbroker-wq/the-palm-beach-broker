  {
    image: 'https://photos.zillowstatic.com/p_e/ISv9p23r1o8yzd0000000000.jpg',
    name: 'SE Walters Ter Home',
    location: 'Port Saint Lucie',
    beds: 3,
    baths: 3,
    sqft: '1,638',
    price: '$374,000',
    tag: 'Sold',
    status: 'Sold',
    address: '834 SE Walters Ter, Port Saint Lucie, FL 34983',
    description: 'Single Family Residence built in 1986. Garden view, pool features.'
  },
  {
    image: 'https://photos.zillowstatic.com/p_e/ISvx5lfzfxqvzd0000000000.jpg',
    name: 'Showboat Lane Estate',
    location: 'Royal Palm Beach',
    beds: 3,
    baths: 3,
    sqft: '2,312',
    price: '$580,000',
