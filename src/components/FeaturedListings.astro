---

<section id=\"properties\" class=\"relative py-32 overflow-hidden bg-black\">
  <!-- Video Background -->
  <div class=\"absolute inset-0 z-0\">
    <div class=\"absolute inset-0 bg-black/60 z-10\"></div>
    <iframe
      class=\"w-full h-full object-cover\"
      src=\"https://www.youtube.com/embed/8v_T75R8QjM?autoplay=1&mute=1&loop=1&playlist=8v_T75R8QjM&controls=0&showinfo=0&rel=0&modestbranding=1\"
      allow=\"autoplay; encrypted-media\"
      frameborder=\"0\"
    ></iframe>
  </div>

  <div class=\"relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">
    <div class=\"text-center mb-20\">
      <p class=\"font-sans text-gold tracking-widest uppercase text-sm mb-3\">Curated Selection</p>
      <h2 class=\"font-serif text-white text-4xl md:text-5xl lg:text-6xl font-light\">Featured Properties</h2>
    </div>

    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10\">
      {listings.map((listing) => (
        <div class=\"group bg-white/5 backdrop-blur-md border border-white/10 overflow-hidden hover:border-gold/50 transition-all duration-500\">
          <div class=\"relative h-80 overflow-hidden\">
            <img 
              src={listing.image} 
              alt={listing.name}
              class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\"
            />
            <div class=\"absolute top-4 left-4\">
              <span class=\"bg-gold text-black px-4 py-1 text-xs font-sans tracking-widest uppercase\">
                {listing.tag}
              </span>
            </div>
            <div class=\"absolute bottom-4 right-4\">
              <span class=\"bg-black/80 backdrop-blur-md text-white px-4 py-1 text-xs font-sans tracking-widest\">
                {listing.soldPrice}
              </span>
            </div>
            {listing.status === 'Sold' && (
              <div class=\"absolute inset-0 bg-black/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity\">
                <div class=\"w-24 h-24 border-2 border-gold rounded-full flex items-center justify-center transform -rotate-12\">
                  <span class=\"text-gold font-serif text-xl\">SOLD</span>
                </div>
              </div>
            )}
          </div>
          
          <div class=\"p-8\">
            <div class=\"flex items-center text-gold/80 text-xs font-sans tracking-widest uppercase mb-3\">
              <span class=\"w-8 h-px bg-gold/30 mr-3\"></span>
              {listing.location}
            </div>
            <h3 class=\"font-serif text-white text-2xl mb-2\">{listing.name}</h3>
            <p class=\"text-white/60 text-sm font-sans mb-4\">{listing.address}</p>
            <p class=\"text-white/80 text-sm font-sans leading-relaxed mb-6 line-clamp-2\">{listing.description}</p>
            
            <div class=\"flex justify-between items-center py-6 border-y border-white/10 mb-6\">
              <div class=\"text-center\">
                <p class=\"text-white font-serif text-lg\">{listing.beds}</p>
                <p class=\"text-white/40 text-[10px] uppercase tracking-widest\">Beds</p>
              </div>
              <div class=\"w-px h-8 bg-white/10\"></div>
              <div class=\"text-center\">
                <p class=\"text-white font-serif text-lg\">{listing.baths}</p>
                <p class=\"text-white/40 text-[10px] uppercase tracking-widest\">Baths</p>
              </div>
              <div class=\"w-px h-8 bg-white/10\"></div>
              <div class=\"text-center\">
                <p class=\"text-white font-serif text-lg\">{listing.sqft}</p>
                <p class=\"text-white/40 text-[10px] uppercase tracking-widest\">Sq Ft</p>
              </div>
            </div>

            {listing.status === 'Sold' && (
              <div class=\"mb-6 flex items-center text-white/60 text-xs font-sans italic\">
                <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"h-4 w-4 mr-2 text-gold/60\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">
                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\" />
                </svg>
                                {listing.buyer}
              </div>
            )}

            <a 
              href={listing.status === 'Sold' ? 'https://www.zillow.com/profile/danirealtor0#listings-and-sales' : '/#contact'} 
              target={listing.status === 'Sold' ? '_blank' : '_self'}
              class=\"block w-full text-center py-4 border border-gold/30 text-gold text-xs font-sans tracking-widest uppercase hover:bg-gold hover:text-black transition-all duration-300\"
            >
              {listing.status === 'Sold' ? 'View Details' : 'Inquire Now'}
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class=\"mt-20 text-center\">
      <a 
        href=\"https://www.zillow.com/profile/danirealtor0#listings-and-sales\" 
        target=\"_blank\"
        class=\"inline-block px-12 py-5 bg-gold text-black text-xs font-sans tracking-widest uppercase hover:bg-white transition-all duration-300\"
      >
        View All Properties
      </a>
    </div>
  </div>
</section>

<section class=\"py-20 bg-forest relative overflow-hidden\">
  <div class=\"max-w-7xl mx-auto px-4 text-center relative z-10\">
    <h2 class=\"font-serif text-white text-3xl md:text-4xl mb-6\">THE PALM BEACH BROKER — Your Trusted Real Estate Partner</h2>
    <blockquote class=\"text-gold font-serif text-2xl italic\">
      “Your needs, always my priority.”
    </blockquote>
  </div>
</section>
