---
const listings = [
  {
    image: 'https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=600&q=80',
    name: 'Ocean Breeze Estate',
    location: 'Palm Beach',
    beds: 5, baths: 6, sqft: '6,200',
    price: '$8,950,000',
    tag: 'Featured'
  },
  {
    image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&q=80',
    name: 'The Meridian Penthouse',
    location: 'Boca Raton',
    beds: 4, baths: 4, sqft: '4,100',
    price: '$4,750,000',
    tag: 'New'
  },
  {
    image: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=600&q=80',
    name: 'Royal Palm Villa',
    location: 'Palm Beach',
    beds: 6, baths: 7, sqft: '8,400',
    price: '$12,500,000',
    tag: 'Exclusive'
  },
  {
    image: 'https://images.unsplash.com/photo-1567496898669-ee935f5f647a?w=600&q=80',
    name: 'Waterfront Sanctuary',
    location: 'Delray Beach',
    beds: 4, baths: 5, sqft: '5,200',
    price: '$6,200,000',
    tag: 'Waterfront'
  },
  {
    image: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=600&q=80',
    name: 'The Grand Residences',
    location: 'Jupiter',
    beds: 5, baths: 5, sqft: '5,000',
    price: '$5,400,000',
    tag: 'New'
  },
  {
    image: 'https://images.unsplash.com/photo-1416331108676-a22ccb276e35?w=600&q=80',
    name: 'Palm Isle Retreat',
    location: 'Wellington',
    beds: 3, baths: 3, sqft: '3,600',
    price: '$2,850,000',
    tag: 'Golf View'
  },
];
---

<section id="properties" class="relative py-20 overflow-hidden">
  <!-- Video Background -->
  <div class="absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover"
      poster="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=80"
    >
      <source src="https://cdn.pixabay.com/video/2020/07/26/45866-446559581_large.mp4" type="video/mp4" />
    </video>
    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/55 to-black/75"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="font-sans text-gold tracking-widest uppercase text-sm mb-3">Curated Selection</p>
      <h2 class="font-serif text-4xl lg:text-5xl text-white font-light">Featured Properties</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {listings.map((listing) => (
        <div class="group bg-white/10 backdrop-blur-sm border border-white/15 hover:border-gold/50 transition-all duration-500 overflow-hidden">
          <div class="relative overflow-hidden h-56">
            <img
              src={listing.image}
              alt={listing.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <span class="absolute top-4 left-4 bg-gold text-white font-sans text-xs tracking-widest uppercase px-3 py-1">{listing.tag}</span>
            <div class="absolute bottom-4 left-4">
              <p class="font-serif text-white text-xl font-light">{listing.price}</p>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-serif text-white text-xl font-light mb-1">{listing.name}</h3>
            <p class="font-sans text-gold text-xs tracking-widest uppercase mb-4">&#9679; {listing.location}</p>
            <div class="flex items-center gap-5 font-sans text-white/70 text-xs mb-6">
              <span>&#127968; {listing.beds} Beds</span>
              <span>&#9049; {listing.baths} Baths</span>
              <span>&#11036; {listing.sqft} sqft</span>
            </div>
            <a href="/#contact" class="block text-center border border-gold text-gold font-sans text-xs tracking-widest uppercase py-3 hover:bg-gold hover:text-white transition-all duration-300">
              View Details
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/#contact" class="inline-block border border-white text-white font-sans text-xs tracking-widest uppercase py-4 px-10 hover:bg-white hover:text-forest transition-all duration-300">
        View All Properties
      </a>
    </div>
  </div>
</section>
