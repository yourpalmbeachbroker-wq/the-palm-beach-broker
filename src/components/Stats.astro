<style>
  .values-slider-container {
    overflow: hidden;
  }
  .values-track {
    animation: scroll-values 20s linear infinite;
    width: max-content;
  }
  .values-track:hover {
    animation-play-state: paused;
  }
  @keyframes scroll-values {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
