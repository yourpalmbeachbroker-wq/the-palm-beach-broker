---
---

<section class="py-12 bg-forest">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-10">
      <p class="font-sans text-gold tracking-widest uppercase text-sm mb-2">Our Values</p>
      <h3 class="font-serif text-3xl text-white font-light">What Defines Us</h3>
      <div class="w-12 h-px bg-gold mx-auto mt-4"></div>
    </div>

    <!-- 3 Values Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gold/20">

      <!-- Integrity -->
      <div class="bg-forest text-center px-8 py-10 group hover:bg-forest/80 transition-colors duration-300">
        <span class="block font-serif text-3xl text-gold mb-4">&#10022;</span>
        <h4 class="font-sans text-white tracking-widest uppercase text-sm font-semibold mb-3">Integrity</h4>
        <div class="w-6 h-px bg-gold/50 mx-auto"></div>
      </div>

      <!-- Client Commitment -->
      <div class="bg-forest text-center px-8 py-10 group hover:bg-forest/80 transition-colors duration-300 border-x border-gold/20">
        <span class="block font-serif text-3xl text-gold mb-4">&#10022;</span>
        <h4 class="font-sans text-white tracking-widest uppercase text-sm font-semibold mb-3">Client Commitment</h4>
        <div class="w-6 h-px bg-gold/50 mx-auto"></div>
      </div>

      <!-- Results -->
      <div class="bg-forest text-center px-8 py-10 group hover:bg-forest/80 transition-colors duration-300">
        <span class="block font-serif text-3xl text-gold mb-4">&#10022;</span>
        <h4 class="font-sans text-white tracking-widest uppercase text-sm font-semibold mb-3">Results</h4>
        <div class="w-6 h-px bg-gold/50 mx-auto"></div>
      </div>

    </div>
  </div>
</section>
