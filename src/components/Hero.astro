---
---
<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background Slideshow -->
  <div class="hero-slideshow absolute inset-0">
    <div class="hero-slide active" style="background-image: url('https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1507089947368-19c1da9775ae?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=1920&q=80'); background-size: cover; background-position: center;"></div>
  </div>

  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/65"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 w-full max-w-5xl mx-auto pt-20">
    <!-- Eyebrow -->
    <p class="text-gold tracking-[0.4em] uppercase text-xs sm:text-sm font-sans font-light mb-6">Palm Beach Luxury Real Estate</p>
    <!-- Headline -->
    <h1 class="font-serif text-4xl sm:text-6xl lg:text-7xl text-white font-light leading-tight mb-4">
      Where Luxury<br /><em class="not-italic text-gold">Meets</em> Lifestyle
    </h1>
    <p class="font-sans text-white/80 text-base sm:text-lg font-light max-w-xl mx-auto mb-10 tracking-wide">
      Discover the finest estates, villas, and penthouses in Palm Beach County
    </p>
    <!-- Search Form -->
    <div class="bg-white/10 backdrop-blur-md border border-white/20 p-6 sm:p-8 rounded-none max-w-4xl mx-auto">
      <form id="search-form" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="flex flex-col">
          <label class="text-gold text-xs tracking-widest uppercase mb-2 font-sans font-light">Location</label>
          <select name="location" class="bg-white/10 border border-white/30 text-white px-4 py-3 text-sm font-sans focus:outline-none focus:border-gold transition-colors">
            <option value="" class="text-gray-900">All Locations</option>
            <option value="palm-beach" class="text-gray-900">Palm Beach</option>
            <option value="boca-raton" class="text-gray-900">Boca Raton</option>
            <option value="delray-beach" class="text-gray-900">Delray Beach</option>
            <option value="wellington" class="text-gray-900">Wellington</option>
            <option value="jupiter" class="text-gray-900">Jupiter</option>
          </select>
        </div>
        <div class="flex flex-col">
          <label class="text-gold text-xs tracking-widest uppercase mb-2 font-sans font-light">Property Type</label>
          <select name="type" class="bg-white/10 border border-white/30 text-white px-4 py-3 text-sm font-sans focus:outline-none focus:border-gold transition-colors">
            <option value="" class="text-gray-900">All Types</option>
            <option value="villa" class="text-gray-900">Villa</option>
            <option value="condo" class="text-gray-900">Condo</option>
            <option value="penthouse" class="text-gray-900">Penthouse</option>
            <option value="estate" class="text-gray-900">Estate</option>
            <option value="waterfront" class="text-gray-900">Waterfront</option>
          </select>
        </div>
        <div class="flex flex-col">
          <label class="text-gold text-xs tracking-widest uppercase mb-2 font-sans font-light">Min Price</label>
          <select name="price" class="bg-white/10 border border-white/30 text-white px-4 py-3 text-sm font-sans focus:outline-none focus:border-gold transition-colors">
            <option value="" class="text-gray-900">Any Price</option>
            <option value="500k" class="text-gray-900">$500K+</option>
            <option value="1m" class="text-gray-900">$1M+</option>
            <option value="3m" class="text-gray-900">$3M+</option>
            <option value="5m" class="text-gray-900">$5M+</option>
            <option value="10m" class="text-gray-900">$10M+</option>
          </select>
        </div>
        <div class="flex flex-col">
          <label class="text-gold text-xs tracking-widest uppercase mb-2 font-sans font-light">&nbsp;</label>
          <button type="submit" class="bg-gold text-white font-sans text-xs tracking-widest uppercase py-3 px-6 hover:bg-gold/90 transition-all duration-300 h-full">
            Search
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .hero-slideshow { position: absolute; inset: 0; }
  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }
  .hero-slide.active { opacity: 1; }
</style>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  let current = 0;
  setInterval(() => {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
  }, 5000);
</script>
