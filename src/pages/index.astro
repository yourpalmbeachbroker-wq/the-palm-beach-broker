<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background Slideshow -->
  <div class="hero-slideshow absolute inset-0">
    <div class="hero-slide active" style="background-image: url('https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1507089947368-19c1da9775ae?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=1920&q=80'); background-size: cover; background-position: center;"></div>
  </div>

  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/65"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 w-full max-w-5xl mx-auto pt-20">
    <!-- Headline -->
    <h1 class="font-serif text-4xl sm:text-6xl lg:text-8xl text-white font-light leading-tight mb-4 uppercase tracking-widest">
      THE PALM BEACH BROKER
    </h1>

    <p class="mt-2 font-sans text-gold tracking-[0.5em] uppercase text-xl sm:text-2xl md:text-3xl font-semibold max-w-3xl mx-auto mb-10 drop-shadow-[0_4px_14px_rgba(0,0,0,0.85)]">
      Real estate with integrity
    </p>
    
    <!-- CTA Button -->
    <div class="flex items-center justify-center mt-8">
      <a 
        href="#contact" 
        class="w-full sm:w-auto bg-transparent text-white font-sans text-xs tracking-widest uppercase py-4 px-10 hover:bg-white hover:text-forest transition-all duration-300 border border-white/30"
      >
        Get in touch
      </a>
    </div>
  </div>
</section>

<style>
  .hero-slideshow { position: absolute; inset: 0; }
  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }
  .hero-slide.active { opacity: 1; }
</style>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  let current = 0;
  setInterval(() => {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
  }, 5000);
</script>---
