---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <style>
      html { scroll-behavior: smooth; }
      * { -webkit-font-smoothing: antialiased; }

      #splash {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #080808;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: opacity 0.8s ease, visibility 0.8s ease;
      }

      #splash.gone {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .sp-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.3rem, 5vw, 4.2rem);
        font-weight: 300;
        color: #fff;
        text-align: center;
        line-height: 1.1;
        margin-bottom: 0.8rem;
      }

      .sp-tag {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #c9a84c;
        margin-bottom: 2.2rem;
        text-align: center;
      }

      .sp-divider {
        width: 70px;
        height: 1px;
        background: #c9a84c;
        margin: 0 auto 2.2rem;
      }

      .sp-btns {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .sp-btn {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        padding: 0.9rem 2.2rem;
        cursor: pointer;
        transition: all 0.3s;
        text-decoration: none;
        border: none;
      }

      .sp-btn-a { background: #c9a84c; color: #fff; }
      .sp-btn-a:hover { background: #b8963e; }

      .sp-btn-b {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,.3);
      }

      .sp-btn-b:hover {
        border-color: #c9a84c;
        color: #c9a84c;
      }

      .sp-skip {
        position: absolute;
        bottom: 1.5rem;
        right: 1.5rem;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,.25);
        cursor: pointer;
        background: none;
        border: none;
        transition: color 0.3s;
      }

      .sp-skip:hover { color: #c9a84c; }

      .wa-btn {
        position: fixed;
        bottom: 4.3rem;
        right: 0.8rem;
        z-index: 1000;
        width: 54px;
        height: 54px;
        background: #25D366;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 18px rgba(0,0,0,.35);
        transition: transform .3s, box-shadow .3s;
        text-decoration: none;
      }

      .wa-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 26px rgba(0,0,0,.5);
      }

      .wa-btn svg {
        width: 28px;
        height: 28px;
        fill: #fff;
      }

      .wa-tip {
        position: absolute;
        right: 68px;
        background: #111;
        color: #fff;
        font-family: 'Montserrat', sans-serif;
        font-size: .65rem;
        letter-spacing: .08em;
        white-space: nowrap;
        padding: .45rem .9rem;
        border-radius: 3px;
        opacity: 0;
        pointer-events: none;
        transition: opacity .3s;
      }

      .wa-btn:hover .wa-tip { opacity: 1; }

      .hero-slideshow { position: absolute; inset: 0; }
      .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 1.5s ease-in-out;
      }
      .hero-slide.active { opacity: 1; }

      @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      .animate-scroll {
        display: flex;
        width: max-content;
        animation: scroll 40s linear infinite;
      }

      .animate-scroll:hover { animation-play-state: paused; }

      .marble-values {
        background:
          radial-gradient(circle at 20% 20%, rgba(209, 169, 93, 0.07), transparent 34%),
          radial-gradient(circle at 80% 30%, rgba(137, 168, 146, 0.11), transparent 36%),
          radial-gradient(circle at 30% 80%, rgba(95, 126, 108, 0.12), transparent 34%),
          linear-gradient(135deg, #11231d 0%, #1a3129 35%, #213c33 65%, #162821 100%);
      }

      .value-card {
        background:
          linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015)),
          linear-gradient(160deg, rgba(95,126,108,0.10), rgba(17,35,29,0.14));
        border: 1px solid rgba(201, 168, 76, 0.16);
        min-height: 132px;
      }

      .properties-overlay {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(to bottom, rgba(0,0,0,0.34), rgba(0,0,0,0.44)),
          radial-gradient(circle at center, rgba(0,0,0,0.10), rgba(0,0,0,0.22) 65%, rgba(0,0,0,0.30));
        backdrop-filter: blur(2px);
      }

      .just-sold-banner {
        position: absolute;
        top: 18px;
        left: -120%;
        z-index: 8;
        background: linear-gradient(90deg, rgba(201,168,76,0.96), rgba(238,221,171,0.96), rgba(201,168,76,0.96));
        color: #111;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.60rem;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        font-weight: 700;
        padding: 0.75rem 1.2rem;
        white-space: nowrap;
        box-shadow: 0 10px 30px rgba(0,0,0,0.22);
      }
      .just-sold-banner.sale-badge-hidden {
        left: -120%;
        opacity: 0;
      }
      .just-sold-banner.sale-badge-animate {
        animation: soldSweep 4s ease-in-out forwards;
      }

      @keyframes soldSweep {
        0% { left: -120%; opacity: 0; }
        10% { opacity: 1; }
        28% { left: 8%; opacity: 1; }
        72% { left: 8%; opacity: 1; }
        100% { left: 120%; opacity: 0; }
      }

      .about-elegant-bg {
        background:
          radial-gradient(circle at 15% 20%, rgba(201,168,76,0.16), transparent 30%),
          radial-gradient(circle at 82% 18%, rgba(255,255,255,0.10), transparent 24%),
          radial-gradient(circle at 70% 70%, rgba(92,121,109,0.18), transparent 30%),
          linear-gradient(125deg, rgba(10,13,12,0.94), rgba(22,28,27,0.86) 40%, rgba(18,34,30,0.84) 70%, rgba(12,16,15,0.93));
      }

      .testimonials-photo-bg {
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(circle at center, rgba(0,0,0,0.30), rgba(0,0,0,0.58) 62%, rgba(0,0,0,0.72)),
          radial-gradient(circle at left center, rgba(201,168,76,0.18), transparent 30%),
          radial-gradient(circle at right center, rgba(69,110,88,0.22), transparent 32%),
          url('/assets/reviewphoto.jpeg');
        background-size: cover;
        background-position: center 30%;
        filter: saturate(1.08) brightness(0.85);
        backdrop-filter: blur(0.5px);
      }
    
      .value-label-shimmer {
        background: linear-gradient(
          90deg,
          rgba(255,255,255,0.95) 0%,
          rgba(201,168,76,1) 40%,
          rgba(255,255,255,0.95) 55%,
          rgba(201,168,76,0.85) 80%,
          rgba(255,255,255,0.9) 100%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmerText 3.5s linear infinite;
      }

      @keyframes shimmerText {
        0% { background-position: 200% center; }
        100% { background-position: -200% center; }
      }

</style>
  </head>

  <body class="font-sans bg-white text-gray-900">
    <div id="splash">
