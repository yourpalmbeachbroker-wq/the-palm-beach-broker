---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'The Palm Beach Broker | Luxury Real Estate Palm Beach Florida',
  description = 'Discover extraordinary luxury properties in Palm Beach, Florida.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style>
      html { scroll-behavior: smooth; }
      * { -webkit-font-smoothing: antialiased; }
      #splash {
        position:fixed;inset:0;z-index:9999;background:#080808;
        display:flex;flex-direction:column;align-items:center;justify-content:center;
        transition:opacity 0.8s ease,visibility 0.8s ease;
      }
      #splash.gone { opacity:0;visibility:hidden;pointer-events:none; }
      .sp-sub { font-family:'Montserrat',sans-serif;font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;color:#c9a84c;margin-bottom:1.2rem; }
      .sp-line { width:50px;height:1px;background:#c9a84c;margin:0 auto 1.5rem; }
      .sp-title { font-family:'Cormorant Garamond',serif;font-size:clamp(2.3rem,5vw,4.2rem);font-weight:300;color:#fff;text-align:center;line-height:1.1;margin-bottom:.8rem; }
      .sp-title em { color:#c9a84c;font-style:italic; }
      .sp-tag { font-family:'Montserrat',sans-serif;font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:#c9a84c;margin-bottom:2.2rem;text-align:center; }
      .sp-divider { width:70px;height:1px;background:#c9a84c;margin:0 auto 2.2rem; }
      .sp-btns { display:flex;gap:1rem;flex-wrap:wrap;justify-content:center; }
      .sp-btn { font-family:'Montserrat',sans-serif;font-size:.65rem;letter-spacing:.25em;text-transform:uppercase;padding:.9rem 2.2rem;cursor:pointer;transition:all .3s;text-decoration:none;border:none; }
      .sp-btn-a { background:#c9a84c;color:#fff; }
      .sp-btn-a:hover { background:#b8963e; }
      .sp-btn-b { background:transparent;color:#fff;border:1px solid rgba(255,255,255,.3); }
      .sp-btn-b:hover { border-color:#c9a84c;color:#c9a84c; }
      .sp-skip { position:absolute;bottom:1.5rem;right:1.5rem;font-family:'Montserrat',sans-serif;font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.25);cursor:pointer;background:none;border:none;transition:color .3s; }
      .sp-skip:hover { color:#c9a84c; }

      /* WhatsApp button: tamaño y posición afinados */
      .wa-btn {
        position:fixed;
        bottom:4.3rem;      /* altura similar al icono azul del navegador */
        right:0.8rem;       /* más a la derecha para separarse del contenido */
        z-index:1000;
        width:54px;
        height:54px;
        background:#25D366;
        border-radius:50%;
        display:flex;
        align-items:center;
        justify-content:center;
        box-shadow:0 4px 18px rgba(0,0,0,.35);
        transition:transform .3s,box-shadow .3s;
        text-decoration:none;
      }
      .wa-btn:hover {
        transform:scale(1.1);
        box-shadow:0 6px 26px rgba(0,0,0,.5);
      }
      .wa-btn svg {
        width:28px;
        height:28px;
        fill:#fff;
      }
      .wa-tip {
        position:absolute;
        right:68px;
        background:#111;
        color:#fff;
        font-family:'Montserrat',sans-serif;
        font-size:.65rem;
        letter-spacing:.08em;
        white-space:nowrap;
        padding:.45rem .9rem;
        border-radius:3px;
        opacity:0;
        pointer-events:none;
        transition:opacity .3s;
      }
      .wa-btn:hover .wa-tip { opacity:1; }
    </style>
  </head>
  <body class="font-sans bg-white text-gray-900">

    <!-- Splash Screen -->
    <div id="splash">
      <h1 class="sp-title">THE PALM BEACH BROKER</h1>

      <p class="sp-tag">REAL ESTATE WITH INTEGRITY</p>

      <div class="sp-divider"></div>

      <div class="sp-btns">
        <a href="/#properties" class="sp-btn sp-btn-a" onclick="hideSplash()">Browse Properties</a>
        <a href="/#contact" class="sp-btn sp-btn-b" onclick="hideSplash()">Get In Touch</a>
      </div>

      <button class="sp-skip" onclick="hideSplash()">Skip Intro &rsaquo;</button>
    </div>

    ---
