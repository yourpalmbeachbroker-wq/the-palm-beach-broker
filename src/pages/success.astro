---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | The Palm Beach Broker">
  <section class="bg-forest min-h-screen flex items-center justify-center py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-sans text-gold tracking-widest uppercase text-sm mb-3">
        Message Sent
      </p>

      <h1 class="font-serif text-4xl lg:text-5xl text-white font-light leading-tight mb-6">
        Thank You
      </h1>

      <div class="w-16 h-px bg-gold mx-auto mb-8"></div>

      <p class="font-sans text-white/80 text-lg leading-relaxed mb-8">
        Your message has been received. A member of The Palm Beach Broker team will be in touch with you shortly.
      </p>

      <a
        href="/"
        class="inline-flex items-center justify-center px-8 py-3 border border-gold text-gold hover:bg-gold hover:text-forest transition-colors duration-300"
      >
        Return Home
      </a>
    </div>
  </section>
</Layout>
