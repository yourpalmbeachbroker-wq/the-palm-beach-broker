---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'The Palm Beach Broker | Luxury Real Estate Palm Beach Florida',
  description = 'Discover extraordinary luxury properties in Palm Beach, Florida.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style>
      html { scroll-behavior: smooth; }
      * { -webkit-font-smoothing: antialiased; }
      #splash { position:fixed;inset:0;z-index:9999;background:#080808;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.8s ease,visibility 0.8s ease; }
      #splash.gone { opacity:0;visibility:hidden;pointer-events:none; }
      .sp-sub { font-family:'Montserrat',sans-serif;font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;color:#c9a84c;margin-bottom:1.2rem; }
      .sp-line { width:50px;height:1px;background:#c9a84c;margin:0 auto 1.5rem; }
      .sp-title { font-family:'Cormorant Garamond',serif;font-size:clamp(2.3rem,5vw,4.2rem);font-weight:300;color:#fff;text-align:center;line-height:1.1;margin-bottom:.8rem; }
      .sp-title em { color:#c9a84c;font-style:italic; }
      .sp-tag { font-family:'Montserrat',sans-serif;font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:#c9a84c;margin-bottom:2.2rem;text-align:center; }
      .sp-divider { width:70px;height:1px;background:#c9a84c;margin:0 auto 2.2rem; }
      .sp-btns { display:flex;gap:1rem;flex-wrap:wrap;justify-content:center; }
      .sp-btn { font-family:'Montserrat',sans-serif;font-size:.65rem;letter-spacing:.25em;text-transform:uppercase;padding:.9rem 2.2rem;cursor:pointer;transition:all .3s;text-decoration:none;border:none; }
      .sp-btn-a { background:#c9a84c;color:#fff; }
      .sp-btn-a:hover { background:#b8963e; }
      .sp-btn-b { background:transparent;color:#fff;border:1px solid rgba(255,255,255,.3); }
      .sp-btn-b:hover { border-color:#c9a84c;color:#c9a84c; }
      .sp-skip { position:absolute;bottom:1.5rem;right:1.5rem;font-family:'Montserrat',sans-serif;font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.25);cursor:pointer;background:none;border:none;transition:color .3s; }
      .sp-skip:hover { color:#c9a84c; }
      .wa-btn { position:fixed;bottom:1.5rem;right:1.5rem;z-index:1000;width:58px;height:58px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 18px rgba(37,211,102,.4);transition:transform .3s,box-shadow .3s;text-decoration:none; }
      .wa-btn:hover { transform:scale(1.1);box-shadow:0 6px 26px rgba(37,211,102,.6); }
      .wa-btn svg { width:30px;height:30px;fill:#fff; }
      .wa-tip { position:absolute;right:68px;background:#111;color:#fff;font-family:'Montserrat',sans-serif;font-size:.65rem;letter-spacing:.08em;white-space:nowrap;padding:.45rem .9rem;border-radius:3px;opacity:0;pointer-events:none;transition:opacity .3s; }
      .wa-btn:hover .wa-tip { opacity:1; }
    </style>
  </head>
  <body class="font-sans bg-white text-gray-900">

    <!-- Splash Screen -->
    <div id="splash">
      <h1 class="sp-title">THE PALM BEACH BROKER</h1>

      <p class="sp-tag">REAL ESTATE WITH INTEGRITY</p>

      <div class="sp-divider"></div>

      <div class="sp-btns">
        <a href="/#properties" class="sp-btn sp-btn-a" onclick="hideSplash()">Browse Properties</a>
        <a href="/#contact" class="sp-btn sp-btn-b" onclick="hideSplash()">Get In Touch</a>
      </div>

      <button class="sp-skip" onclick="hideSplash()">Skip Intro &rsaquo;</button>
    </div>

    <slot />

    <!-- WhatsApp Float -->
    <a href="https://wa.me/17869758002" target="_blank" rel="noopener noreferrer" class="wa-btn" aria-label="Chat on WhatsApp">
      <span class="wa-tip">Chat on WhatsApp</span>
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </a>

    <script>
      function hideSplash() {
        var s = document.getElementById('splash');
        if (s) { s.classList.add('gone'); setTimeout(function(){ s.remove(); }, 800); sessionStorage.setItem('sp','1'); }
      }
      document.addEventListener('DOMContentLoaded', function() {
        if (sessionStorage.getItem('sp')) {
          var s = document.getElementById('splash');
          if (s) s.remove();
        } else {
          setTimeout(hideSplash, 6000);
        }
      });
    </script>

    <!-- begin Widget Tracker Code -->
    <script>
    (function(w,i,d,g,e,t){w["WidgetTrackerObject"]=g;(w[g]=w[g]||function() {(w[g].q=w[g].q||[]).push(arguments);}),(w[g].ds=1*new Date());(e="script"),
    (t=d.createElement(e)),(e=d.getElementsByTagName(e)[0]);t.async=1;t.src=i;
    e.parentNode.insertBefore(t,e);})
    (window,"https://widgetbe.com/agent",document,"widgetTracker");
    window.widgetTracker("create", "WT-SZUKOEQU");
    window.widgetTracker("send", "pageview");
    </script>
    <!-- end Widget Tracker Code -->

  </body>
</html>
